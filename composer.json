{
    "name": "dhensby/silverstripe-copybutton",
    "type": "silverstripe-vendormodule",
    "license": "BSD-3-Clause",
    "description": "Adds copy button to the GridField.",
    "keywords": [
        "silverstripe",
        "copy",
        "button"
    ],
    "authors": [
        {
            "name": "Elvinas Liutkevičius",
            "email": "elvinas@unisolutions.eu"
        }
    ],
    "require": {
        "silverstripe/framework": "^4 || ^5"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7"
    },
    "scripts": {
        "lint": "phpcs code/ tests/",
        "lint:fix": "phpcbf code/ tests/"
    },
    "autoload": {
        "psr-4": {
            "Unisolutions\\": "code/"
        }
    },
    "replace": {
        "unisolutions/silverstripe-copybutton": "self.version"
    },
    "config":{
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev"
        },
        "expose": [
            "css"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
